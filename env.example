# ============================================
# CONFIGURAÇÃO DO BOT WHATSAPP
# ============================================

# Ambiente (development, production)
NODE_ENV=production

# Porta do servidor
PORT=3000

# Caminho para salvar credenciais WhatsApp
# (Você pode deixar vazio para usar padrão)
AUTH_PATH=./auth_info_baileys

# ============================================
# CONFIGURAÇÕES DE SERVIDOR (Railway/Render)
# ============================================

# Railway (preenchido automaticamente)
# RAILWAY_PUBLIC_DOMAIN=seu-projeto.railway.app

# Render (preenchido automaticamente)
# RENDER_EXTERNAL_URL=https://seu-projeto.onrender.com

# ============================================
# INTEGRAÇÕES FUTURAS (opcional)
# ============================================

# API Keys para funcionalidades extras
# API_WEATHER=sua_chave_aqui
# API_TRANSLATE=sua_chave_aqui
# WEBHOOK_URL=seu_webhook_aqui

# ============================================
# LOGS E DEBUG
# ============================================

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Ativar detalhes de conexão (true/false)
DEBUG=false

# ============================================
# CONFIGURAÇÕES DE MENSAGEM
# ============================================

# Responder automaticamente a certas palavras
AUTO_REPLY=true

# Prefixo dos comandos (vazio = sem prefixo)
COMMAND_PREFIX=

# ============================================
# SEGURANÇA
# ============================================

# Senhas ou tokens sensíveis aqui
# ADMIN_PASSWORD=sua_senha_super_secreta
# API_TOKEN=seu_token_aqui
